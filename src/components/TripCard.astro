---
import type { CollectionEntry } from 'astro:content';
import { render, getCollection } from 'astro:content';
import { formatLongDate } from '../lib/format';

interface Props {
  trip: CollectionEntry<'trips'>;
}

const { trip } = Astro.props;
const {
  title,
  location,
  country,
  startDate,
  endDate,
  status,
  coverPalette,
  coverImage,
  coverPosition,
} = trip.data;

const { Content } = await render(trip);

const dateRange = endDate
  ? `${formatLongDate(startDate)} — ${formatLongDate(endDate)}`
  : formatLongDate(startDate);

const href = `/travels/${trip.id}`;

// Count related entries so we can label the link accurately.
const allEntries = await getCollection('entries', ({ data }) => !data.draft);
const relatedCount = allEntries.filter(
  (e) => e.data.location.trim().toLowerCase() === location.trim().toLowerCase(),
).length;
---

<article class="trip" id={`trip-${trip.id}`}>
  <header class="trip-header">
    <p class="meta">
      <span class="status" data-status={status}>
        {status === 'past' ? 'visited' : 'planned'}
      </span>
      <span class="sep">·</span>
      <span>{dateRange}</span>
    </p>
    <a href={href} class="title-link">
      <h2 class="title">{title}</h2>
    </a>
    <p class="location"><em>{location}, {country}</em></p>
  </header>

  <a href={href} class="cover-link">
    {
      coverImage ? (
        <img
          src={coverImage}
          alt={`${location}, ${country}`}
          class="cover-img"
          style={`object-position: ${coverPosition};`}
          loading="lazy"
        />
      ) : (
        <div class:list={['cover hero', `hero--${coverPalette}`]} aria-hidden="true" />
      )
    }
  </a>

  <div class="trip-body prose">
    <Content />
  </div>

  <p class="see-more">
    <a href={href}>
      {
        relatedCount > 0
          ? `see photos & ${relatedCount} journal ${relatedCount === 1 ? 'entry' : 'entries'} →`
          : 'see photos →'
      }
    </a>
  </p>
</article>

<style>
  .trip {
    padding: 2rem 0 2.5rem;
    border-bottom: 1px solid var(--border-soft);
    scroll-margin-top: 2rem;
  }

  .trip:last-child { border-bottom: none; }

  .trip-header { margin-bottom: 1.25rem; }

  .meta {
    font-style: italic;
    font-size: 0.78rem;
    color: var(--c-ink);
    letter-spacing: 0.06em;
    margin: 0 0 0.5rem;
  }

  .status[data-status="past"] { color: var(--c-terracotta-deep); font-weight: 500; }
  .status[data-status="upcoming"] { color: var(--c-ink); font-weight: 500; }
  .sep { color: var(--c-warm-brown); margin: 0 0.4rem; }

  .title-link, .cover-link {
    display: block;
    border: none;
    color: inherit;
  }

  .title-link:hover, .cover-link:hover { color: inherit; }

  .title-link:hover .title {
    color: var(--c-terracotta-deep);
  }

  .title {
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 500;
    color: var(--c-espresso);
    margin: 0 0 0.4rem;
    line-height: 1.2;
    transition: color 0.2s ease;
    text-wrap: balance;
  }

  .location {
    margin: 0;
    font-size: 0.95rem;
    color: var(--c-warm-brown);
  }

  .cover, .cover-img {
    aspect-ratio: 16 / 7;
    width: 100%;
    margin: 1.5rem 0;
    border-radius: 2px;
    object-fit: cover;
    display: block;
  }

  .trip-body p {
    font-size: 1rem;
    line-height: 1.75;
  }

  .see-more {
    margin: 1.25rem 0 0;
    font-style: italic;
    font-size: 0.95rem;
  }

  .see-more a {
    color: var(--c-ink);
    border-bottom: none;
  }

  .see-more a:hover {
    color: var(--c-terracotta-deep);
  }

  @media (max-width: 640px) {
    .title { font-size: 1.4rem; }
  }
</style>
