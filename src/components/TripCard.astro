---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import { formatLongDate } from '../lib/format';

interface Props {
  trip: CollectionEntry<'trips'>;
}

const { trip } = Astro.props;
const { title, location, country, startDate, endDate, status, coverPalette, coverImage, photos } =
  trip.data;

const { Content } = await render(trip);

const dateRange = endDate
  ? `${formatLongDate(startDate)} — ${formatLongDate(endDate)}`
  : formatLongDate(startDate);
---

<article class="trip" id={`trip-${trip.id}`}>
  <a href={`#trip-${trip.id}`} class="anchor" aria-hidden="true"></a>

  <header class="trip-header">
    <p class="meta">
      <span class="status" data-status={status}>
        {status === 'past' ? 'visited' : 'planned'}
      </span>
      <span class="sep">·</span>
      <span>{dateRange}</span>
    </p>
    <h2 class="title">{title}</h2>
    <p class="location">
      <em>{location}, {country}</em>
    </p>
  </header>

  {
    coverImage ? (
      <img src={coverImage} alt={`${location}, ${country}`} class="cover" loading="lazy" />
    ) : (
      <div class:list={['cover hero', `hero--${coverPalette}`]} aria-hidden="true" />
    )
  }

  <div class="trip-body prose">
    <Content />
  </div>

  {
    photos && photos.length > 0 && (
      <div class:list={['photos', `photos--${photos.length === 1 ? 'one' : 'grid'}`]}>
        {photos.map((src) => (
          <img src={src} alt={`${location}`} class="photo" loading="lazy" />
        ))}
      </div>
    )
  }
</article>

<style>
  .trip {
    padding: 2rem 0 2.5rem;
    border-bottom: 1px solid var(--border-soft);
    scroll-margin-top: 2rem;
  }

  .trip:last-child { border-bottom: none; }

  .anchor {
    position: absolute;
    visibility: hidden;
  }

  .trip-header {
    margin-bottom: 1.25rem;
  }

  .meta {
    font-style: italic;
    font-size: 0.78rem;
    color: var(--c-ink);
    letter-spacing: 0.06em;
    margin: 0 0 0.5rem;
  }

  .status[data-status="past"] { color: var(--c-terracotta-deep); }
  .status[data-status="upcoming"] { color: var(--c-ink); }

  .sep { color: var(--c-warm-brown); margin: 0 0.4rem; }

  .title {
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 500;
    color: var(--c-espresso);
    margin: 0 0 0.4rem;
    line-height: 1.2;
  }

  .location {
    margin: 0;
    font-size: 0.95rem;
    color: var(--c-warm-brown);
  }

  .cover {
    aspect-ratio: 16 / 7;
    width: 100%;
    margin: 1.5rem 0;
    border-radius: 2px;
    object-fit: cover;
    display: block;
  }

  .trip-body p {
    font-size: 1rem;
    line-height: 1.75;
  }

  .photos {
    display: grid;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .photos--one { grid-template-columns: 1fr; }
  .photos--grid {
    grid-template-columns: repeat(auto-fit, minmax(min(220px, 100%), 1fr));
  }

  .photo {
    width: 100%;
    height: auto;
    border-radius: 2px;
    object-fit: cover;
    aspect-ratio: 4 / 3;
  }

  @media (max-width: 640px) {
    .title { font-size: 1.4rem; }
  }
</style>
