---
import type { CollectionEntry } from 'astro:content';
import { formatDay } from '../lib/format';

interface Props {
  entry: CollectionEntry<'entries'>;
}

const { entry } = Astro.props;
const {
  title,
  dek,
  publishDate,
  location,
  heroPalette,
  heroImage,
  heroAlt,
  heroPosition,
} = entry.data;
const day = formatDay(publishDate);
---

<article class="featured">
  <p class="date">{day} — {location}</p>
  <a href={`/entries/${entry.id}`} class="hero-link">
    {
      heroImage ? (
        <img
          src={heroImage}
          alt={heroAlt ?? title}
          class="featured-img"
          style={`object-position: ${heroPosition};`}
          loading="eager"
        />
      ) : (
        <div class:list={['hero', 'hero--featured', `hero--${heroPalette}`]} />
      )
    }
  </a>
  <a href={`/entries/${entry.id}`} class="title-link">
    <h2 class="title">{title}</h2>
  </a>
  {dek && <p class="dek">{dek}</p>}
  <p class="read-on">
    <a href={`/entries/${entry.id}`}>read on →</a>
  </p>
</article>

<style>
  .featured {
    padding: 2rem clamp(1rem, 5vw, 2.5rem) 0.5rem;
    max-width: var(--measure-wide);
    margin-inline: auto;
  }

  .date {
    font-style: italic;
    color: var(--c-ink);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    margin: 0 0 0.75rem;
  }

  .hero-link, .title-link {
    border: none;
    display: block;
    color: inherit;
  }

  .hero-link:hover, .title-link:hover { color: inherit; }

  /* Slightly less wide than the original 16:7 — leaves more vertical
     room for sky / horizon / sun, so the top of the image isn't cut. */
  .hero--featured {
    aspect-ratio: 16 / 9;
  }

  .featured-img {
    aspect-ratio: 16 / 9;
    width: 100%;
    object-fit: cover;
    display: block;
    border-radius: 2px;
  }

  .title-link:hover .title { color: var(--c-terracotta-deep); }

  .title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 4vw, 2rem);
    font-weight: 500;
    color: var(--c-espresso);
    line-height: 1.18;
    margin: 1.2rem 0 0.6rem;
    letter-spacing: -0.005em;
    transition: color 0.2s ease;
    text-wrap: balance;
  }

  .dek {
    font-style: italic;
    color: var(--c-espresso-soft);
    font-size: clamp(0.95rem, 2.5vw, 1.05rem);
    line-height: 1.55;
    margin: 0 0 1rem;
  }

  .read-on {
    margin: 0;
    font-style: italic;
    font-size: 0.92rem;
  }

  .read-on a {
    color: var(--c-ink);
    border-bottom: none;
  }

  .read-on a:hover {
    color: var(--c-terracotta-deep);
  }
</style>
