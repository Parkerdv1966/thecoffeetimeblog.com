---
import type { CollectionEntry } from 'astro:content';
import { formatDay } from '../lib/format';

interface Props {
  entry: CollectionEntry<'entries'>;
}

const { entry } = Astro.props;
const { title, dek, mode, publishDate, location, heroPalette } = entry.data;
const day = formatDay(publishDate);
---

<article class="featured">
  <p class="date">{day} — {location}</p>
  <a href={`/entries/${entry.id}`} class="hero-link">
    <div class:list={['hero', 'hero--featured', `hero--${heroPalette}`]}></div>
  </a>
  <a href={`/entries/${entry.id}`} class="title-link">
    <h2 class="title">{title}</h2>
  </a>
  {dek && <p class="dek">{dek}</p>}
  <p class="read-on">
    <a href={`/entries/${entry.id}`}>read on →</a>
  </p>
</article>

<style>
  .featured {
    padding: 2rem var(--gutter-wide) 0.5rem;
    max-width: var(--measure-wide);
    margin-inline: auto;
  }

  .date {
    font-style: italic;
    color: var(--c-ink);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    margin: 0 0 0.75rem;
  }

  .hero-link, .title-link {
    border: none;
    display: block;
    color: inherit;
  }

  .hero-link:hover, .title-link:hover { color: inherit; }

  .hero--featured {
    aspect-ratio: 16 / 7;
  }

  .title-link:hover .title { color: var(--c-terracotta-deep); }

  .title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 500;
    color: var(--c-espresso);
    line-height: 1.18;
    margin: 1.2rem 0 0.6rem;
    letter-spacing: -0.005em;
    transition: color 0.2s ease;
  }

  .dek {
    font-style: italic;
    color: var(--c-espresso-soft);
    font-size: 1.05rem;
    line-height: 1.55;
    margin: 0 0 1rem;
  }

  .read-on {
    margin: 0;
    font-style: italic;
    font-size: 0.92rem;
  }

  .read-on a {
    color: var(--c-ink);
    border-bottom: none;
  }

  .read-on a:hover {
    color: var(--c-terracotta-deep);
  }

  @media (max-width: 640px) {
    .title { font-size: 1.5rem; }
    .dek { font-size: 0.95rem; }
  }
</style>
