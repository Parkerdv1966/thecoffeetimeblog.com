---
import type { CollectionEntry } from 'astro:content';
import { formatDay } from '../lib/format';

interface Props {
  entry: CollectionEntry<'entries'>;
}

const { entry } = Astro.props;
const { title, mode, publishDate, location, dek, heroPalette, heroImage } = entry.data;
const day = formatDay(publishDate);
---

<article class="entry-card">
  <a href={`/entries/${entry.id}`} class="card-link">
    {heroImage
      ? <div class="hero"><img src={heroImage} alt={title} /></div>
      : <div class:list={['hero', `hero--${heroPalette}`]}></div>
    }
    <p class="meta">
      <span class="day">{day}</span>
      <span class="sep"> — </span>
      <span class="mode">{mode}</span>
    </p>
    <h2 class="title">{title}</h2>
    {dek && <p class="dek">{dek}</p>}
    <p class="location">{location}</p>
  </a>
</article>

<style>
  .entry-card { margin: 0; }

  .card-link {
    display: block;
    border: none;
    color: inherit;
  }

  .card-link:hover { color: inherit; }

  .card-link:hover .title {
    color: var(--c-terracotta-deep);
  }

  .hero {
    aspect-ratio: 16 / 10;
    margin-bottom: 0.85rem;
    transition: transform 0.4s ease;
  }

  .card-link:hover .hero {
    transform: scale(1.005);
  }

  .meta {
    font-style: italic;
    color: var(--c-ink);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    margin: 0 0 0.35rem;
  }

  .sep { color: var(--c-warm-brown); }

  .title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--c-espresso);
    line-height: 1.25;
    margin: 0 0 0.5rem;
    transition: color 0.2s ease;
  }

  .dek {
    font-style: italic;
    color: var(--c-espresso-soft);
    font-size: 0.92rem;
    line-height: 1.55;
    margin: 0 0 0.5rem;
  }

  .location {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    color: var(--c-warm-brown);
    margin: 0;
    text-transform: lowercase;
  }
</style>
