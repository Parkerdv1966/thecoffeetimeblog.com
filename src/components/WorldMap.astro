---
import type { CollectionEntry } from 'astro:content';

interface Props {
  trips: CollectionEntry<'trips'>[];
  mapImage?: string;
  heightMode?: 'natural' | 'shorter' | 'shortest';
  focalPoint?: 'center' | 'top' | 'bottom';
  pastMarkerSize?: 'small' | 'medium' | 'large';
  upcomingMarkerSize?: 'small' | 'medium' | 'large';
  showFrame?: boolean;
}

const {
  trips,
  mapImage = '/images/world-map.png',
  heightMode = 'natural',
  focalPoint = 'center',
  pastMarkerSize = 'medium',
  upcomingMarkerSize = 'medium',
  showFrame = true,
} = Astro.props;

const VIEW_W = 1000;
const VIEW_H = 500;

// Marker radii from size names
const PAST_R     = { small: 5, medium: 7, large: 9 }[pastMarkerSize];
const UPCOMING_R = { small: 4, medium: 6, large: 8 }[upcomingMarkerSize];

// Map block aspect ratio (CSS) — controls how much vertical space the
// rendered map takes. Projection math stays 2:1 because the SVG viewBox
// is fixed; this just crops the rendered area.
const aspectCss = {
  natural:  '2 / 1',
  shorter:  '5 / 2',
  shortest: '3 / 1',
}[heightMode];

// preserveAspectRatio alignment based on focal point.
// "slice" = cover-style fit (no letterboxing, crops the overflow).
const preserveAR =
  focalPoint === 'top'    ? 'xMidYMin slice' :
  focalPoint === 'bottom' ? 'xMidYMax slice' :
                            'xMidYMid slice';

const paletteFill: Record<string, string> = {
  terracotta: '#C46B47',
  sage:       '#6B7F5C',
  ocean:      '#4A6478',
  gold:       '#C9A661',
  espresso:   '#5B3A22',
};

// Equirectangular projection: lat/lng → x/y in the viewBox.
// Works correctly as long as the background image is also equirectangular
// (2:1 aspect ratio, evenly spaced lat/lng across the image).
function project(lat: number, lng: number) {
  const x = ((lng + 180) / 360) * VIEW_W;
  const y = ((90 - lat) / 180) * VIEW_H;
  return { x, y };
}

// Preview card dimensions
const PW = 130;
const PH = 90;

const markers = trips.map((trip) => {
  const { x, y } = project(trip.data.coordinates.lat, trip.data.coordinates.lng);

  const above = y > 130;
  let px = x - PW / 2;
  let py = above ? y - PH - 18 : y + 18;

  if (px < 4) px = 4;
  if (px + PW > VIEW_W - 4) px = VIEW_W - PW - 4;

  return {
    id: trip.id,
    href: `/travels/${trip.id}`,
    x,
    y,
    px,
    py,
    status: trip.data.status,
    label: trip.data.location,
    country: trip.data.country,
    coverImage: trip.data.coverImage,
    palette: trip.data.coverPalette,
    above,
  };
});
---

<figure class="map-figure">
  <figcaption class="map-caption">
    <span class="caption-text">a map of where i've been &amp; where i'm going</span>
  </figcaption>

  <div class:list={['map-frame', { 'map-frame--bare': !showFrame }]} style={`aspect-ratio: ${aspectCss};`}>
    <svg
      viewBox={`0 0 ${VIEW_W} ${VIEW_H}`}
      xmlns="http://www.w3.org/2000/svg"
      class="map-svg"
      preserveAspectRatio={preserveAR}
      role="img"
      aria-label="World map showing trip destinations"
    >
      <!-- Parchment fallback fill in case the image fails to load -->
      <rect width="1000" height="500" fill="#D9C9A3" />

      <!-- The world map image. Path comes from src/data/map-settings.json,
           editable via the admin. Must be 2:1 equirectangular for markers to
           land in geographically correct places. -->
      <image
        href={mapImage}
        x="0"
        y="0"
        width="1000"
        height="500"
        preserveAspectRatio="none"
      />

      <!-- Markers + previews -->
      <g class="markers">
        {
          markers.map((m) => (
            <a href={m.href} class={`marker marker--${m.status}`} aria-label={`${m.label}, ${m.country} (${m.status === 'past' ? 'visited' : 'planned'})`}>
              <g class="preview" pointer-events="none">
                <rect x={m.px - 2} y={m.py - 2} width={PW + 4} height={PH + 4} class="preview-shadow" />
                <rect x={m.px} y={m.py} width={PW} height={PH} class="preview-bg" />
                {m.coverImage ? (
                  <image
                    href={m.coverImage}
                    x={m.px + 4}
                    y={m.py + 4}
                    width={PW - 8}
                    height={PH - 26}
                    preserveAspectRatio="xMidYMid slice"
                  />
                ) : (
                  <rect x={m.px + 4} y={m.py + 4} width={PW - 8} height={PH - 26} fill={paletteFill[m.palette]} />
                )}
                <text
                  x={m.px + PW / 2}
                  y={m.py + PH - 8}
                  text-anchor="middle"
                  class="preview-text"
                >
                  {m.label}
                </text>
                {m.above ? (
                  <polygon points={`${m.x - 6},${m.py + PH} ${m.x + 6},${m.py + PH} ${m.x},${m.py + PH + 8}`} class="preview-pointer" />
                ) : (
                  <polygon points={`${m.x - 6},${m.py} ${m.x + 6},${m.py} ${m.x},${m.py - 8}`} class="preview-pointer" />
                )}
              </g>

              <circle cx={m.x} cy={m.y} r={m.status === 'past' ? PAST_R : UPCOMING_R} class="marker-dot" />
              {m.status === 'upcoming' && (
                <circle cx={m.x} cy={m.y} r={UPCOMING_R} class="marker-ring" />
              )}
              <text x={m.x} y={m.y - 13} text-anchor="middle" class="marker-label">
                {m.label}
              </text>
            </a>
          ))
        }
      </g>
    </svg>

    <p class="legend">
      <span class="legend-item"><span class="dot dot--past"></span> visited</span>
      <span class="legend-sep">·</span>
      <span class="legend-item"><span class="dot dot--upcoming"></span> planned</span>
      <span class="legend-sep">·</span>
      <span class="legend-item-hint"><em>hover for preview, click to open</em></span>
    </p>
  </div>
</figure>

<style>
  .map-figure {
    margin: 0 0 2.5rem;
  }

  .map-caption {
    text-align: center;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.9rem;
    color: var(--c-warm-brown);
    margin: 0 0 0.75rem;
    letter-spacing: 0.04em;
  }

  .caption-text { padding: 0 0.75rem; }

  /* Frame around the map — gives it presence and contains it
     visually whether the image is loaded or not. */
  .map-frame {
    background: #D9C9A3;
    border: 1px solid var(--border-strong);
    border-radius: 4px;
    padding: clamp(0.5rem, 1.5vw, 1rem);
    box-shadow:
      inset 0 0 0 1px rgba(74, 40, 24, 0.08),
      inset 0 0 30px rgba(74, 40, 24, 0.05);
    overflow: hidden;
  }

  .map-frame--bare {
    background: transparent;
    border: none;
    border-radius: 0;
    padding: 0;
    box-shadow: none;
  }

  .map-svg {
    width: 100%;
    height: 100%;
    display: block;
    border-radius: 2px;
  }

  .marker { cursor: pointer; }
  .marker[href] { text-decoration: none; }

  /* Markers — terracotta with a cream halo so they read clearly on
     any background, including the vintage map's sepia tones. */
  .marker-dot {
    fill: var(--c-terracotta);
    stroke: var(--c-cream-soft);
    stroke-width: 1.5;
    transition: transform 0.2s ease;
    transform-origin: center;
    transform-box: fill-box;
    filter: drop-shadow(0 1px 2px rgba(74, 40, 24, 0.4));
  }

  .marker--upcoming .marker-dot {
    fill: var(--c-cream-soft);
    stroke: var(--c-terracotta);
    stroke-width: 2;
  }

  .marker-ring {
    fill: none;
    stroke: var(--c-terracotta);
    stroke-width: 1;
    opacity: 0.5;
  }

  .marker-label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    fill: var(--c-espresso);
    opacity: 0;
    transition: opacity 0.15s ease;
    pointer-events: none;
    paint-order: stroke;
    stroke: var(--c-cream-soft);
    stroke-width: 3;
  }

  .preview {
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .preview-shadow {
    fill: rgba(74, 40, 24, 0.25);
  }

  .preview-bg {
    fill: var(--c-cream-soft);
    stroke: var(--c-espresso);
    stroke-width: 1;
  }

  .preview-pointer {
    fill: var(--c-cream-soft);
    stroke: var(--c-espresso);
    stroke-width: 1;
  }

  .preview-text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 12px;
    fill: var(--c-espresso);
    font-weight: 500;
  }

  .marker:hover .preview,
  .marker:focus .preview {
    opacity: 1;
  }

  .marker:hover .marker-dot,
  .marker:focus .marker-dot {
    transform: scale(1.4);
  }

  .marker:not(:hover):not(:focus) .marker-label {
    opacity: 0;
  }

  .marker:hover .marker-label,
  .marker:focus .marker-label {
    opacity: 0;
  }

  .legend {
    text-align: center;
    margin: 0.85rem 0 0;
    font-size: 0.78rem;
    color: var(--c-warm-brown);
    letter-spacing: 0.04em;
  }

  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .legend-item-hint {
    font-style: italic;
    color: var(--c-ink);
    opacity: 0.75;
  }

  .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    display: inline-block;
  }

  .dot--past {
    background: var(--c-terracotta);
    border: 1.5px solid var(--c-cream-soft);
  }

  .dot--upcoming {
    background: var(--c-cream-soft);
    border: 2px solid var(--c-terracotta);
  }

  .legend-sep {
    margin: 0 0.6rem;
    opacity: 0.6;
  }

  @media (max-width: 600px) {
    .legend-item-hint { display: none; }
    .legend-sep:last-of-type { display: none; }
  }
</style>
