---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<header class:list={['site-header', { compact }]}>
  <a href="/" class="logo-link">
    <h1 class="logo">the coffee time</h1>
  </a>
  {!compact && <p class="subtitle">— travels &amp; writing —</p>}
  {
    !compact && (
      <nav class="nav">
        <a href="/">essays</a>
        <span class="dot">·</span>
        <a href="/?mode=travels">travels</a>
        <span class="dot">·</span>
        <a href="/books">the books</a>
        <span class="dot">·</span>
        <a href="/about">about</a>
      </nav>
    )
  }
</header>

<style>
  .site-header {
    text-align: center;
    padding: 2.5rem var(--gutter-wide) 1.5rem;
    border-bottom: 1px solid var(--border-medium);
  }

  .site-header.compact {
    padding: 1.25rem var(--gutter-wide);
  }

  .logo-link {
    border: none;
    color: inherit;
    display: inline-block;
  }

  .logo-link:hover { color: inherit; }

  .logo {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    color: var(--c-espresso);
    letter-spacing: 0.01em;
    margin: 0;
  }

  .site-header:not(.compact) .logo {
    font-size: 2.2rem;
  }

  .site-header.compact .logo {
    font-size: 1.25rem;
  }

  .subtitle {
    font-style: italic;
    color: var(--c-ink);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    margin: 0.5rem 0 0;
  }

  .nav {
    margin-top: 1.1rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.85rem;
    flex-wrap: wrap;
    font-style: italic;
    font-size: 0.92rem;
  }

  .nav a {
    color: var(--c-espresso);
    border-bottom: none;
    transition: color 0.2s ease;
  }

  .nav a:hover {
    color: var(--c-terracotta-deep);
  }

  .dot {
    color: var(--c-warm-brown);
  }
</style>

	}
</style>
