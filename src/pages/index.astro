---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeaturedEntry from '../components/FeaturedEntry.astro';
import EntryCard from '../components/EntryCard.astro';
import CurrentlyWriting from '../components/CurrentlyWriting.astro';
import Ornament from '../components/Ornament.astro';
import { getCollection } from 'astro:content';

const allEntries = (await getCollection('entries', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const featured = allEntries[0];
const recent = allEntries.slice(1, 5);
---

<BaseLayout>
  {featured && <FeaturedEntry entry={featured} />}

  <Ornament />

  <section class="recent" aria-labelledby="recent-heading">
    <h2 id="recent-heading" class="section-label">recent entries</h2>
    <div class="grid">
      {recent.map((entry) => <EntryCard entry={entry} />)}
    </div>
  </section>

  <CurrentlyWriting
    title='"The Long Hours"'
    description="A short story about a translator who can't sleep. Started in a Vienna café, still being figured out."
  />
</BaseLayout>

<style>
  .recent {
    max-width: var(--measure-wide);
    margin-inline: auto;
    padding: 0 var(--gutter-wide) 1rem;
  }

  .section-label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--c-ink);
    letter-spacing: 0.22em;
    text-align: center;
    margin: 0 0 1.75rem;
    text-transform: lowercase;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2rem 1.75rem;
  }

  @media (max-width: 640px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
  }
</style>
