---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorldMap from '../../components/WorldMap.astro';
import TripCard from '../../components/TripCard.astro';
import Ornament from '../../components/Ornament.astro';
import { getCollection } from 'astro:content';
import mapSettings from '../../data/map-settings.json';

const allTrips = (await getCollection('trips', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf(),
);

const past = allTrips.filter((t) => t.data.status === 'past');
const upcoming = allTrips.filter((t) => t.data.status === 'upcoming');
---

<BaseLayout title="travels" compact={true}>
  <article class="travels">
    <header class="travels-header">
      <p class="kicker">travels</p>
      <h1 class="title">where i've been, where i'm going</h1>
      <p class="subtitle">
        A running map of trips taken and trips planned. Click a marker for the
        entry.
      </p>
    </header>

    <div class="map-wrapper">
      <WorldMap trips={allTrips} {...mapSettings} />
    </div>

    <Ornament spacing="tight" />

    {
      past.length > 0 && (
        <section class="section" aria-labelledby="past-heading">
          <h2 id="past-heading" class="section-label">visited</h2>
          <div class="trips">
            {past.map((trip) => (
              <TripCard trip={trip} />
            ))}
          </div>
        </section>
      )
    }

    {
      upcoming.length > 0 && (
        <section class="section" aria-labelledby="upcoming-heading">
          <h2 id="upcoming-heading" class="section-label">planned</h2>
          <div class="trips">
            {upcoming.map((trip) => (
              <TripCard trip={trip} />
            ))}
          </div>
        </section>
      )
    }
  </article>
</BaseLayout>

<style>
  .travels {
    max-width: var(--measure-wide);
    margin-inline: auto;
    padding: 2rem clamp(1rem, 5vw, 2.5rem) 1rem;
  }

  .travels-header { text-align: center; margin-bottom: 1.5rem; }

  .kicker {
    font-style: italic;
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    color: var(--c-ink);
    margin: 0 0 0.85rem;
  }

  .title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 500;
    color: var(--c-espresso);
    line-height: 1.15;
    margin: 0 0 0.75rem;
    text-wrap: balance;
  }

  .subtitle {
    font-style: italic;
    color: var(--c-warm-brown);
    font-size: 0.95rem;
    margin: 0;
    text-wrap: balance;
  }

  .section {
    margin-top: 2rem;
    padding-top: 1rem;
  }

  .section-label {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 0.85rem;
    color: var(--c-ink);
    letter-spacing: 0.22em;
    text-align: center;
    margin: 0 0 1.25rem;
    text-transform: lowercase;
  }
</style>
