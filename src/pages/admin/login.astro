---
export const prerender = false;

import { verifyToken, parseSessionCookie } from '../../lib/auth';

const runtimeEnv = (Astro.locals as any).runtime?.env;
const secret: string = runtimeEnv?.SESSION_SECRET ?? import.meta.env.SESSION_SECRET ?? '';

const token = parseSessionCookie(Astro.request.headers.get('cookie'));
if (token && secret && (await verifyToken(token, secret))) {
  return Astro.redirect('/admin');
}

const error = Astro.url.searchParams.get('error');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>admin — the coffee time</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main>
      <div class="card">
        <p class="brand">the coffee time</p>
        <h1>admin</h1>
        {error && <p class="error">incorrect password — try again</p>}
        <form method="POST" action="/api/admin/login">
          <label for="password">password</label>
          <input
            type="password"
            id="password"
            name="password"
            autocomplete="current-password"
            autofocus
            required
          />
          <button type="submit">sign in →</button>
        </form>
      </div>
    </main>
  </body>
</html>

<style>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: 'Fraunces', Georgia, serif;
    background: #f1e6cc;
    color: #4a2818;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .card {
    width: 100%;
    max-width: 22rem;
    padding: 2.5rem;
    border: 1px solid rgba(74, 40, 24, 0.25);
    border-radius: 2px;
    background: #faefd9;
    text-align: center;
  }

  .brand {
    font-style: italic;
    color: #8b6038;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    margin-bottom: 0.35rem;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
  }

  .error {
    font-style: italic;
    color: #8b3d2a;
    font-size: 0.85rem;
    margin-bottom: 1.25rem;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    text-align: left;
  }

  label {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: #8b6038;
    text-transform: lowercase;
  }

  input[type='password'] {
    width: 100%;
    padding: 0.6rem 0.75rem;
    border: 1px solid rgba(74, 40, 24, 0.25);
    border-radius: 2px;
    background: #f1e6cc;
    color: #4a2818;
    font-family: inherit;
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s;
  }

  input[type='password']:focus {
    border-color: #1f2b45;
  }

  button[type='submit'] {
    width: 100%;
    padding: 0.65rem;
    margin-top: 0.5rem;
    background: #4a2818;
    color: #f1e6cc;
    border: none;
    border-radius: 2px;
    font-family: inherit;
    font-size: 0.92rem;
    font-style: italic;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: background 0.2s;
  }

  button[type='submit']:hover {
    background: #8b3d2a;
  }
</style>
