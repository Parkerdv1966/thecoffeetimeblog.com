---
import BaseLayout from '../layouts/BaseLayout.astro';
import Ornament from '../components/Ornament.astro';
---

<BaseLayout title="about" compact={true}>
  <article class="about">
    <header class="about-header">
      <p class="kicker">about</p>
      <h1 class="title">a few words on this place</h1>
    </header>

    <Ornament spacing="tight" />

    <div class="prose">
      <p>
        this is a personal journal kept by someone who travels, writes, and
        spends a lot of afternoons in cafés trying to finish a chapter. the
        entries are short. the photographs are often the point. the coffee is
        almost always the throughline — not because i'm a coffee person
        exactly, but because every café has a colour, and every city has a
        light, and a flat white in lisbon is not the same drink as a flat
        white in melbourne, even when the recipe is identical.
      </p>

      <p>
        most days here will be one of three modes: <em>travels</em>, when i'm
        somewhere new; <em>writing</em>, when i'm working on a story or a
        chapter and want to think out loud; and <em>café</em>, which is the
        small daily one — a place, a cup, what the room felt like.
      </p>

      <p>
        the longer pieces become <em>essays</em>. the longest ones, eventually,
        will become books.
      </p>

      <p>— Parker</p>
    </div>
  </article>
</BaseLayout>

<style>
  .about {
    max-width: var(--measure);
    margin-inline: auto;
    padding: 2rem var(--gutter-wide) 1rem;
  }

  .about-header { text-align: center; }

  .kicker {
    font-style: italic;
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    color: var(--c-ink);
    margin: 0 0 0.85rem;
  }

  .title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 500;
    color: var(--c-espresso);
    line-height: 1.15;
    margin: 0;
  }

  .prose p {
    font-size: 1.05rem;
    line-height: 1.85;
  }

  @media (max-width: 640px) {
    .title { font-size: 1.5rem; }
  }
</style>
