---
import EntryLayout from '../../layouts/EntryLayout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const all = (await getCollection('entries', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
  );

  return all.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      // newer entry → "next" (so the chronological forward direction is "next")
      next: all[i - 1],
      prev: all[i + 1],
    },
  }));
};

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
---

<EntryLayout entry={entry} prev={prev} next={next}>
  <Content />
</EntryLayout>
