---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkCard from '../components/WorkCard.astro';
import Ornament from '../components/Ornament.astro';
import { getCollection } from 'astro:content';

const allWorks = (await getCollection('works', ({ data }) => !data.draft)).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);

const inProgress = allWorks.filter((w) => w.data.status !== 'finished');
const finished = allWorks
  .filter((w) => w.data.status === 'finished')
  .sort((a, b) => {
    const aDate = a.data.finishedDate?.valueOf() ?? 0;
    const bDate = b.data.finishedDate?.valueOf() ?? 0;
    return bDate - aDate;
  });
---

<BaseLayout title="the books" compact={true}>
  <article class="books">
    <header class="books-header">
      <p class="kicker">the books</p>
      <h1 class="title">what i'm working on</h1>
      <p class="subtitle">
        Stories, essays, and longer pieces — at various stages of finished.
      </p>
    </header>

    {
      inProgress.length > 0 && (
        <section class="section" aria-labelledby="inprogress-heading">
          <h2 id="inprogress-heading" class="section-label">in progress</h2>
          <div class="works">
            {inProgress.map((work) => (
              <WorkCard work={work} />
            ))}
          </div>
        </section>
      )
    }

    <Ornament spacing="wide" />

    {
      finished.length > 0 && (
        <section class="section" aria-labelledby="finished-heading">
          <h2 id="finished-heading" class="section-label">finished works</h2>
          <div class="works">
            {finished.map((work) => (
              <WorkCard work={work} />
            ))}
          </div>
        </section>
      )
    }

    {
      allWorks.length === 0 && (
        <p class="empty">
          <em>Nothing here yet — first work coming soon.</em>
        </p>
      )
    }
  </article>
</BaseLayout>

<style>
  .books {
    max-width: var(--measure);
    margin-inline: auto;
    padding: 2rem clamp(1rem, 5vw, 2.5rem) 1rem;
  }

  .books-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .kicker {
    font-style: italic;
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    color: var(--c-ink);
    margin: 0 0 0.85rem;
  }

  .title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 500;
    color: var(--c-espresso);
    line-height: 1.15;
    margin: 0 0 0.75rem;
    text-wrap: balance;
  }

  .subtitle {
    font-style: italic;
    color: var(--c-warm-brown);
    font-size: 0.95rem;
    margin: 0;
    text-wrap: balance;
  }

  .section { margin-top: 1rem; }

  .section-label {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 0.85rem;
    color: var(--c-ink);
    letter-spacing: 0.22em;
    text-align: center;
    margin: 0 0 1rem;
    text-transform: lowercase;
  }

  .empty {
    text-align: center;
    color: var(--c-warm-brown);
    margin: 3rem 0;
  }
</style>
