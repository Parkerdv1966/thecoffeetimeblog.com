---
import BaseLayout from './BaseLayout.astro';
import PrevNext from '../components/PrevNext.astro';
import Ornament from '../components/Ornament.astro';
import { formatDateline } from '../lib/format';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'entries'>;
  prev?: CollectionEntry<'entries'>;
  next?: CollectionEntry<'entries'>;
}

const { entry, prev, next } = Astro.props;
const { title, dek, publishDate, location, heroPalette, heroImage, heroAlt } = entry.data;
const dateline = formatDateline(publishDate, location);
---

<BaseLayout title={title} description={dek} compact={true}>
  <article class="entry">
    {
      heroImage ? (
        <img
          src={heroImage}
          alt={heroAlt ?? title}
          class="entry-hero-img"
          loading="eager"
        />
      ) : (
        <div class:list={['hero', 'hero--post', `hero--${heroPalette}`]} />
      )
    }

    <header class="entry-header">
      <p class="dateline">{dateline}</p>
      <h1 class="title">{title}</h1>
      {dek && <p class="dek">{dek}</p>}
    </header>

    <Ornament spacing="tight" />

    <div class="prose">
      <slot />
    </div>

    <Ornament spacing="wide" />
  </article>

  <PrevNext prev={prev} next={next} />
</BaseLayout>

<style>
  .entry {
    max-width: var(--measure-wide);
    margin-inline: auto;
  }

  .hero--post,
  .entry-hero-img {
    aspect-ratio: 16 / 7;
    width: 100%;
    margin: 0;
    border-radius: 0;
    object-fit: cover;
    display: block;
  }

  .entry-header {
    text-align: center;
    padding: clamp(1.5rem, 5vw, 2.25rem) clamp(1rem, 5vw, 2.5rem) 0.5rem;
    max-width: var(--measure);
    margin-inline: auto;
  }

  .dateline {
    font-style: italic;
    font-size: 0.82rem;
    color: var(--c-ink);
    letter-spacing: 0.1em;
    margin: 0 0 0.85rem;
  }

  .title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 5vw, 2.4rem);
    font-weight: 500;
    color: var(--c-espresso);
    line-height: 1.15;
    margin: 0 0 0.85rem;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  .dek {
    font-style: italic;
    font-size: clamp(0.95rem, 2.5vw, 1.05rem);
    color: var(--c-warm-brown);
    line-height: 1.55;
    margin: 0;
    text-wrap: balance;
  }

  .prose {
    max-width: var(--measure);
    margin-inline: auto;
    padding: 0 clamp(1rem, 5vw, 2.5rem);
  }

  .prose p {
    hyphens: auto;
    -webkit-hyphens: auto;
    overflow-wrap: break-word;
  }
</style>
